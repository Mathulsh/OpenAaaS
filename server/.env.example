# OpenAaaS Server 环境变量示例
# 复制此文件为 .env 并根据需要修改
# 环境变量格式: APP__<SECTION>__<KEY>=value，双下划线表示嵌套

# 服务器地址
APP__SERVER__ADDR=0.0.0.0:8080

# 请求超时（秒）
APP__SERVER__TIMEOUT_SECS=30

# 最大请求体大小（字节）
APP__SERVER__MAX_BODY_SIZE=10485760

# 数据库路径
APP__DATABASE__URL=sqlite:./data/app.db

# Agent 心跳超时（秒）
APP__AGENT__HEARTBEAT_TIMEOUT_SECS=60

# 任务结果保留天数
APP__TASK__RESULT_RETENTION_DAYS=7

# 文件存储路径
APP__TASK__FILE_STORAGE_PATH=./data/files

# 单文件大小限制（MB）
APP__TASK__MAX_FILE_SIZE_MB=50

# HMAC 密钥（生产环境必须修改）
APP__SECRET_KEY=change-me-in-production

# 管理员 API Key
APP__ADMIN_API_KEY=from-config-admin-key

# 日志级别
APP__LOG_LEVEL=info

# 快捷覆盖（无前缀），优先级高于 APP__ADMIN_API_KEY
# 如果同时设置 ADMIN_API_KEY 和 APP__ADMIN_API_KEY，以 ADMIN_API_KEY 为准
ADMIN_API_KEY=runtime-admin-key

# 精细化日志控制（可选）
# RUST_LOG=open_aaas_server=debug,tower_http=debug
