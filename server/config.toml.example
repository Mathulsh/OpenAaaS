# Generated by direct server startup.
# Secret Key：用于HMAC哈希API Key，首次启动时生成，部署后请勿更改
secret_key = "change-me-in-production"

# Admin API key: used for admin APIs and agent-core token generation.
# admin_api_key = "your-secure-admin-key"
log_level = "info"

[server]
# 监听地址
addr = "0.0.0.0:8080"
# 请求超时时间(秒)
timeout_secs = 30
# 最大请求体大小(字节)
max_body_size = 10485760

[database]
# 数据库连接URL (SQLite)
url = "sqlite:./data/app.db"

[agent]
# 心跳超时(秒)，用于判断Agent是否离线
heartbeat_timeout_secs = 60

[task]
# 任务结果保留时间(天)
result_retention_days = 7
# 文件存储路径
file_storage_path = "./data/files"
# 最大文件大小限制(MB)
max_file_size_mb = 50
